{
  "version": "1.0.0",
  "roles": {
    "intake": {
      "stage_owner": ["Understand"],
      "prompt_focus": [
        "任务理解与契约化",
        "触发词识别",
        "需求标题化",
        "约束抽取"
      ],
      "must_check": [
        "目标是否明确",
        "约束是否明确",
        "是否存在隐含依赖",
        "是否触发 @intake / @init / @plan / @risk / @decision / @audit / @ask / @ppw / @6A / @6AYH / @PPW / @sdd",
        "首个状态流转是否为 submitted->triaged"
      ],
      "outputs": [
        "结构化任务卡",
        "推荐工作流",
        "是否需要进入 review-gate",
        "工作流必需文档清单",
        "文档版本号",
        "首条 handoff 记录",
        "职责转移提示"
      ]
    },
    "planner": {
      "stage_owner": ["Plan"],
      "prompt_focus": [
        "方案设计",
        "两案对比",
        "任务拆解",
        "架构边界"
      ],
      "must_check": [
        "至少两个方案是否齐全",
        "复杂度、成本、风险是否对比",
        "适用边界是否明确",
        "是否满足 KISS / YAGNI / DRY / SOLID",
        "planned 状态和 current_stage 是否同步更新"
      ],
      "outputs": [
        "执行计划",
        "原子任务清单",
        "设计文档建议",
        "文档初始化计划",
        "代码修改目标清单",
        "状态更新理由",
        "阶段职责转移提示"
      ]
    },
    "review-gate": {
      "stage_owner": ["ReviewGate"],
      "prompt_focus": [
        "风险评审",
        "变更控制",
        "执行前自检",
        "审批"
      ],
      "must_check": [
        "是否存在破坏性操作",
        "是否需要显式确认",
        "是否存在不可控风险",
        "是否需要回退到 Understand",
        "审批结论是否符合状态机"
      ],
      "outputs": [
        "通过/驳回结论",
        "风险登记",
        "回退建议",
        "驳回原因与修正要求",
        "审批后的职责转移提示"
      ]
    },
    "orchestrator": {
      "stage_owner": ["Execute", "Report"],
      "prompt_focus": [
        "任务调度",
        "结果汇总",
        "状态追踪",
        "阶段报告"
      ],
      "must_check": [
        "路由是否符合权限矩阵",
        "是否记录 handoff 原因",
        "是否明确写出职责从谁转移到谁",
        "是否收齐执行部门结果",
        "是否输出风险与降级",
        "工作流必需文档是否已初始化或更新",
        "状态迁移是否符合 status-transitions.json"
      ],
      "outputs": [
        "派单记录",
        "汇总报告",
        "最终结果摘要",
        "文档状态汇总",
        "阶段状态变更记录",
        "执行职责转移提示"
      ]
    },
    "engineering": {
      "stage_owner": ["ExecutionWorker"],
      "prompt_focus": [
        "代码实现",
        "测试验证",
        "功能交付"
      ],
      "must_check": [
        "是否遵循批准任务执行",
        "是否保持最小变更面",
        "是否提供测试或验证说明",
        "是否记录了修改文件位置与前后代码片段"
      ],
      "outputs": [
        "代码变更",
        "文件位置与行号",
        "修改前代码片段",
        "修改后代码片段",
        "测试说明",
        "实现摘要"
      ]
    },
    "docs-spec": {
      "stage_owner": ["DocumentationWorker"],
      "prompt_focus": [
        "设计文档",
        "对齐文档",
        "验收文档",
        "总结文档"
      ],
      "must_check": [
        "文档命名是否规范",
        "是否记录决策与依据",
        "是否标记遗留问题",
        "是否记录代码修改文件位置与前后代码片段",
        "文档目录版本号是否正确"
      ],
      "outputs": [
        "文档草案",
        "总结报告",
        "审计性记录",
        "工作流文档骨架",
        "代码修改定位清单"
      ]
    },
    "data-ops": {
      "stage_owner": ["CostWorker"],
      "prompt_focus": [
        "复杂度成本",
        "资源评估",
        "报表生成"
      ],
      "must_check": [
        "是否说明复杂度成本",
        "是否说明人力与运维成本"
      ],
      "outputs": [
        "成本视图",
        "资源评估"
      ]
    },
    "security": {
      "stage_owner": ["SecurityWorker"],
      "prompt_focus": [
        "安全检查",
        "合规审计",
        "红线把控"
      ],
      "must_check": [
        "是否涉及敏感信息",
        "是否影响权限与合规",
        "是否存在发布风险"
      ],
      "outputs": [
        "风险清单",
        "审计意见"
      ]
    },
    "platform": {
      "stage_owner": ["PlatformWorker"],
      "prompt_focus": [
        "工具链",
        "构建发布",
        "MCP 调用纪律"
      ],
      "must_check": [
        "构建与发布方式是否明确",
        "运行时和环境是否明确",
        "工具调用是否需要降级路径"
      ],
      "outputs": [
        "构建发布建议",
        "工具调用简报",
        "CI/CD 注意事项"
      ]
    },
    "governance": {
      "stage_owner": ["GovernanceWorker"],
      "prompt_focus": [
        "权限维护",
        "Agent 管理",
        "治理材料"
      ],
      "must_check": [
        "权限矩阵是否被正确使用",
        "是否需要新增触发词或角色"
      ],
      "outputs": [
        "治理变更建议",
        "权限更新记录",
        "职位注册表更新建议"
      ]
    }
  }
}
