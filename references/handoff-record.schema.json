{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HandoffRecord",
  "type": "object",
  "required": [
    "handoff_id",
    "task_id",
    "from",
    "to",
    "status_before",
    "status_after",
    "reason",
    "decision_summary",
    "inputs",
    "outputs",
    "risks",
    "next_action"
  ],
  "properties": {
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "status_before": {
      "type": "string",
      "minLength": 1
    },
    "status_after": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "decision_summary": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string"
    },
    "rejected_by": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
