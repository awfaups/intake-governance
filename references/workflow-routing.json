{
  "version": "1.3.0",
  "entry_agent": "intake",
  "external_entry_rule": "all_external_multi_agent_requests_must_enter_via_intake",
  "aliases": {
    "@init": {
      "owner": "intake",
      "workflow": "project_init",
      "then": ["planner", "platform", "docs-spec"],
      "description": "项目初始化分析"
    },
    "@plan": {
      "owner": "intake",
      "workflow": "planning",
      "then": ["planner", "review-gate", "orchestrator"],
      "description": "任务规划"
    },
    "@refactor": {
      "owner": "intake",
      "workflow": "progressive_refactor",
      "then": ["planner", "review-gate", "orchestrator", "engineering"],
      "description": "重构模式"
    },
    "@risk": {
      "owner": "intake",
      "workflow": "risk_review",
      "then": ["planner", "review-gate", "orchestrator", "security"],
      "description": "风险评估"
    },
    "@decision": {
      "owner": "intake",
      "workflow": "technical_decision",
      "then": ["planner", "review-gate", "data-ops", "orchestrator"],
      "description": "技术选型决策"
    },
    "@audit": {
      "owner": "intake",
      "workflow": "architecture_audit",
      "then": ["planner", "review-gate", "security", "docs-spec", "orchestrator"],
      "description": "架构 / 代码审计"
    },
    "@ask": {
      "owner": "intake",
      "workflow": "quick_decompose",
      "then": ["planner"],
      "description": "快速问题拆解"
    },
    "@ppw": {
      "owner": "intake",
      "workflow": "ppw",
      "then": ["planner", "docs-spec", "review-gate"],
      "description": "启动项目流程梳理",
      "canonical_abbreviation": "PMW",
      "legacy_alias": true
    },
    "@6A": {
      "owner": "intake",
      "workflow": "6a",
      "then": ["planner", "review-gate", "orchestrator", "engineering", "docs-spec"],
      "description": "新增功能开发工作流",
      "activation_response": "6A工作流已激活\n当前阶段：Align（需求对齐）"
    },
    "@6AYH": {
      "owner": "intake",
      "workflow": "6ayh",
      "then": ["planner", "review-gate", "orchestrator", "engineering", "docs-spec", "security"],
      "description": "6A 优化型工作流",
      "canonical_abbreviation": "6AO",
      "legacy_alias": true,
      "activation_response": "✅ 6A Optimization 工作流（6AO）已激活\n当前阶段：Align（目标与风险对齐）"
    },
    "@6AO": {
      "owner": "intake",
      "workflow": "6ayh",
      "then": ["planner", "review-gate", "orchestrator", "engineering", "docs-spec", "security"],
      "description": "6A Optimization 工作流",
      "canonical_abbreviation": "6AO",
      "activation_response": "✅ 6A Optimization 工作流（6AO）已激活\n当前阶段：Align（目标与风险对齐）"
    },
    "@PPW": {
      "owner": "intake",
      "workflow": "ppw",
      "then": ["planner", "docs-spec", "review-gate"],
      "description": "项目流程梳理工作流",
      "canonical_abbreviation": "PMW",
      "legacy_alias": true,
      "activation_response": "✅ Project Mapping Workflow（PMW · 项目流程梳理工作流）已激活\n当前阶段：A1 – 项目资产盘点（Inventory）"
    },
    "@PMW": {
      "owner": "intake",
      "workflow": "ppw",
      "then": ["planner", "docs-spec", "review-gate"],
      "description": "Project Mapping Workflow",
      "canonical_abbreviation": "PMW",
      "activation_response": "✅ Project Mapping Workflow（PMW · 项目流程梳理工作流）已激活\n当前阶段：A1 – 项目资产盘点（Inventory）"
    },
    "@sdd": {
      "owner": "intake",
      "workflow": "sdd",
      "then": ["planner", "review-gate", "orchestrator", "engineering", "docs-spec"],
      "description": "规格驱动开发工作流",
      "canonical_abbreviation": "SDD",
      "legacy_alias": true,
      "activation_response": "✅ Specification-Driven Development 工作流（SDD）已激活\n当前阶段：Spec（规格定义）"
    },
    "@SDD": {
      "owner": "intake",
      "workflow": "sdd",
      "then": ["planner", "review-gate", "orchestrator", "engineering", "docs-spec"],
      "description": "Specification-Driven Development",
      "canonical_abbreviation": "SDD",
      "activation_response": "✅ Specification-Driven Development 工作流（SDD）已激活\n当前阶段：Spec（规格定义）"
    },
    "@GGW": {
      "owner": "intake",
      "workflow": "generic_governance",
      "then": ["planner", "review-gate", "orchestrator"],
      "description": "Generic Governance Workflow",
      "canonical_abbreviation": "GGW",
      "activation_response": "通用治理工作流（GGW · Generic Governance Workflow）已激活\n当前阶段：Intake（治理意图归一）"
    }
  },
  "auto_classification": {
    "6a": {
      "match_any_signals": [
        "新增功能",
        "新功能",
        "新增能力",
        "开发一个",
        "开发页面",
        "开发模块",
        "新增页面",
        "新增模块",
        "从0到1",
        "从零开始",
        "新页面",
        "新模块",
        "greenfield",
        "feature",
        "new feature",
        "new page",
        "new module",
        "build from scratch"
      ],
      "emit_activation_response": true,
      "canonical_abbreviation": "6A",
      "canonical_name": "Align, Architect, Atomize, Approve, Automate, Assess",
      "activation_response": "6A工作流已激活\n当前阶段：Align（需求对齐）"
    },
    "6ayh": {
      "match_any_signals": [
        "重构",
        "优化",
        "渐进式优化",
        "性能优化",
        "维护成本高",
        "卡顿",
        "状态混乱",
        "技术债",
        "可维护性",
        "行为保持",
        "refactor",
        "optimize",
        "cleanup",
        "tech debt",
        "maintainability",
        "behavior preserving"
      ],
      "emit_activation_response": true,
      "canonical_abbreviation": "6AO",
      "canonical_name": "6A Optimization",
      "legacy_abbreviation": "6AYH",
      "activation_response": "✅ 6A Optimization 工作流（6AO）已激活\n当前阶段：Align（目标与风险对齐）"
    },
    "ppw": {
      "match_any_signals": [
        "项目梳理",
        "项目盘点",
        "项目现状不清",
        "流程梳理",
        "全面盘点",
        "项目资产盘点",
        "现状梳理",
        "资产映射",
        "摸清楚",
        "资产和流程",
        "流程摸清楚",
        "inventory",
        "roadmap",
        "process discovery",
        "asset mapping",
        "current state"
      ],
      "emit_activation_response": true,
      "canonical_abbreviation": "PMW",
      "canonical_name": "Project Mapping Workflow",
      "legacy_abbreviation": "PPW",
      "activation_response": "✅ Project Mapping Workflow（PMW · 项目流程梳理工作流）已激活\n当前阶段：A1 – 项目资产盘点（Inventory）"
    },
    "sdd": {
      "match_any_signals": [
        "sdd",
        "spec-driven",
        "spec driven",
        "规格驱动",
        "规格驱动开发",
        "先写规格",
        "先写 spec",
        "需求规格",
        "验收标准",
        "spec first",
        "spec as source",
        "specification",
        "acceptance criteria"
      ],
      "emit_activation_response": true,
      "canonical_abbreviation": "SDD",
      "canonical_name": "Specification-Driven Development",
      "activation_response": "✅ Specification-Driven Development 工作流（SDD）已激活\n当前阶段：Spec（规格定义）"
    },
    "generic_governance": {
      "fallback": true,
      "emit_activation_response": true,
      "canonical_abbreviation": "GGW",
      "canonical_name": "Generic Governance Workflow",
      "activation_response": "通用治理工作流（GGW · Generic Governance Workflow）已激活\n当前阶段：Intake（治理意图归一）"
    }
  }
}
