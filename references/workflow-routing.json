{
  "version": "1.0.0",
  "entry_agent": "taizi",
  "external_entry_rule": "all_external_multi_agent_requests_must_enter_via_taizi",
  "aliases": {
    "@init": {
      "owner": "taizi",
      "workflow": "project_init",
      "then": ["zhongshu", "gongbu", "libu"],
      "description": "项目初始化分析"
    },
    "@plan": {
      "owner": "taizi",
      "workflow": "planning",
      "then": ["zhongshu", "menxia", "shangshu"],
      "description": "任务规划"
    },
    "@refactor": {
      "owner": "taizi",
      "workflow": "progressive_refactor",
      "then": ["zhongshu", "menxia", "shangshu", "bingbu"],
      "description": "重构模式"
    },
    "@risk": {
      "owner": "taizi",
      "workflow": "risk_review",
      "then": ["zhongshu", "menxia", "shangshu", "xingbu"],
      "description": "风险评估"
    },
    "@decision": {
      "owner": "taizi",
      "workflow": "technical_decision",
      "then": ["zhongshu", "menxia", "hubu", "shangshu"],
      "description": "技术选型决策"
    },
    "@audit": {
      "owner": "taizi",
      "workflow": "architecture_audit",
      "then": ["zhongshu", "menxia", "xingbu", "libu", "shangshu"],
      "description": "架构 / 代码审计"
    },
    "@ask": {
      "owner": "taizi",
      "workflow": "quick_decompose",
      "then": ["zhongshu"],
      "description": "快速问题拆解"
    },
    "@ppw": {
      "owner": "taizi",
      "workflow": "ppw",
      "then": ["zhongshu", "libu", "menxia"],
      "description": "启动项目流程梳理"
    },
    "@6A": {
      "owner": "taizi",
      "workflow": "6a",
      "then": ["zhongshu", "menxia", "shangshu", "bingbu", "libu"],
      "description": "新增功能开发工作流",
      "activation_response": "✅ 6A 前端开发流程已激活\n当前任务类型：【新增功能开发】\n当前阶段：Align（目标对齐）"
    },
    "@6AYH": {
      "owner": "taizi",
      "workflow": "6ayh",
      "then": ["zhongshu", "menxia", "shangshu", "bingbu", "xingbu"],
      "description": "渐进式优化工作流",
      "activation_response": "✅ 6A 优化工作流（6AYH · 前端渐进式优化模式）已激活\n当前阶段：Align（目标与风险对齐）"
    },
    "@PPW": {
      "owner": "taizi",
      "workflow": "ppw",
      "then": ["zhongshu", "libu", "menxia"],
      "description": "项目流程梳理工作流",
      "activation_response": "✅ 项目流程梳理工作流（PPW）已激活\n当前阶段：A1 – 项目资产盘点（Inventory）"
    }
  },
  "auto_classification": {
    "6a": {
      "match_any_signals": [
        "新增功能",
        "新功能",
        "开发一个",
        "开发页面",
        "开发模块",
        "新增页面",
        "新增模块",
        "从0到1",
        "feature",
        "new feature"
      ],
      "emit_activation_response": true
    },
    "6ayh": {
      "match_any_signals": [
        "重构",
        "优化",
        "渐进式优化",
        "性能优化",
        "维护成本高",
        "卡顿",
        "状态混乱",
        "refactor",
        "optimize"
      ],
      "emit_activation_response": true
    },
    "ppw": {
      "match_any_signals": [
        "项目梳理",
        "项目盘点",
        "项目现状不清",
        "流程梳理",
        "全面盘点",
        "项目资产盘点",
        "inventory",
        "roadmap"
      ],
      "emit_activation_response": true
    },
    "generic_governance": {
      "fallback": true
    }
  }
}
